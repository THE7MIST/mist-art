{
  "id": "mist.disk.sleuthkit",
  "name": "Disk Filesystem Analysis",
  "category": "disk",
  "version": "0.1.0",
  "description": "Enumerates partitions, filesystems, visible files, deleted records, unallocated ranges, and archive candidates using Sleuth Kit-compatible workflows.",
  "inputs": ["E01", "Ex01", "dd", "raw", "001", "img", "vmdk", "vhd", "vhdx", "qcow2", "vdi"],
  "outputs": ["partitions", "filesystem", "files", "deleted_files", "zip_candidates", "tsk_commands"],
  "tools": ["mmls", "fsstat", "fls", "icat", "istat", "blkls", "tsk_recover"],
  "enabled": true,
  "sandbox": {
    "mount": "read-only",
    "network": "disabled",
    "cpu_limit": "2",
    "memory_limit": "4g"
  }
}
