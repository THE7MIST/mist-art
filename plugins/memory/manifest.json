{
  "id": "mist.memory.volatility3",
  "name": "Memory Analysis",
  "category": "memory",
  "version": "0.1.0",
  "description": "Runs Volatility-style memory workflows for processes, DLLs, network activity, handles, registry, credentials, and malware indicators.",
  "inputs": ["memory.raw", "mem", "vmem", "lime", "hiberfil.sys", "pagefile.sys"],
  "outputs": ["processes", "dlls", "network_connections", "handles", "credentials", "malware_indicators"],
  "tools": ["volatility3"],
  "enabled": true,
  "sandbox": {
    "mount": "read-only",
    "network": "disabled",
    "cpu_limit": "2",
    "memory_limit": "6g"
  }
}
